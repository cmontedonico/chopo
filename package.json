{
  "name": "chopo-v1",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "convex": "^1.32.0",
      "better-auth": "1.4.9",
      "@convex-dev/better-auth": "^0.10.13",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "check-types": "turbo check-types",
    "check:format": "node node_modules/oxfmt/dist/cli.js --check .",
    "check:ci": "node node_modules/oxlint/dist/cli.js && node node_modules/oxfmt/dist/cli.js --check . && bun run check-types",
    "commitlint": "commitlint --config commitlint.config.mjs",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @chopo-v1/backend dev",
    "dev:setup": "turbo -F @chopo-v1/backend dev:setup",
    "check": "node node_modules/oxlint/dist/cli.js && node node_modules/oxfmt/dist/cli.js --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@chopo-v1/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@chopo-v1/config": "workspace:*",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "node node_modules/oxlint/dist/cli.js"
    ],
    "*": [
      "node node_modules/oxfmt/dist/cli.js --write"
    ]
  },
  "packageManager": "bun@1.2.18"
}
